{
  "configurations": [
  {
    "name": "Python: Current File",
    "type": "debugpy",
    "request": "launch",
    "program": "${file}",
    "console": "integratedTerminal",
    "args": ["--model-provider=ollama", "--model=nomic-embed-text"],
    "env": {
      "PYTHONPATH": "${workspaceFolder}"
    }
  }
]
}
